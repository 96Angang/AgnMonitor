# =============================================================================
# AgnMonitor 환경변수 예시 파일
# 이 파일을 복사하여 data/.env 를 만들고 실제 값으로 채우세요.
#   cp data/.env.example data/.env
# data/.env 는 절대 git 에 커밋하지 마세요 (.gitignore 에 등록되어 있음).
# =============================================================================

# ── Django ──────────────────────────────────────────────────────────────────
# SECRET_KEY 를 비워두면 data/.secret_key 파일에 자동 생성됩니다.
# SECRET_KEY='your-django-secret-key-here'
DEBUG=True

# 개발/수정자가 models.py 변경 후 컨테이너 시작 시 migration 파일 생성을 원할 때만 True.
# 공개 릴리스/운영 기본값은 False 권장.
RUN_MAKEMIGRATIONS=False

# 기본 관리자(superuser) 계정 - 최초 1회 자동 생성됩니다. 운영 시 반드시 변경하세요.
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=change-me-please

# ── Database (MariaDB/MySQL) ─────────────────────────────────────────────────
# Django 가 사용하는 접속 정보
DB_ENGINE=django.db.backends.mysql
DB_NAME=AgnMonitor
DB_USER=AgnMonitor
DB_PASSWORD=change-me-db-password
DB_HOST=mariadb
DB_PORT=3306

# MariaDB 컨테이너 초기화용 (위 DB_* 값과 일치시키세요)
MARIADB_DATABASE=AgnMonitor
MARIADB_USER=AgnMonitor
MARIADB_PASSWORD=change-me-db-password
MARIADB_ROOT_PASSWORD=change-me-root-password

# ── Redis / Valkey ───────────────────────────────────────────────────────────
REDIS_URL=redis://valkey:6379/0

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-email-password
DEFAULT_FROM_EMAIL=AgnMonitor Alert <your-email@example.com>

# ── 접근 제어 / CSRF ─────────────────────────────────────────────────────────
# /admin 접근을 허용할 추가 IP 대역 (콤마 구분). 기본 사설 대역은 자동 허용됩니다.
# ADMIN_ALLOWED_NETWORKS=203.0.113.0/24,198.51.100.10/32

# CSRF 신뢰 서브넷(/24 프리픽스, 콤마 구분)과 포트
# CSRF_TRUSTED_SUBNETS=192.168.10,192.168.50
CSRF_TRUSTED_PORTS=18080,8000
# 전체 URL 형태로 추가 신뢰 오리진을 지정 (콤마 구분)
# CSRF_TRUSTED_ORIGINS_EXTRA=https://monitor.example.com
